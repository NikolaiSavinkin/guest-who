{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.back.tsbuildinfo",
    "composite": true,
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    /* Add other options as needed */
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "references": [{"path": "../shared"}]
}
