{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    /* Add other options as needed */
    "baseUrl": ".",
    "paths": {"@shared/*": ["../shared/src/*"]}
  },
  "include": ["src/**/*", "../shared/src/schema.ts", "../shared/src/types.d.ts"], // Only compile files in the src directory
  "exclude": ["node_modules"], // Exclude node_modules
  "references": [{"path": "../shared"}],
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}
