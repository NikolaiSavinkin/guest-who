{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "module": "CommonJS"
  },
  "include": ["src/**/*.ts", "src/types.d.ts"],
  "exclude": ["**/*.test.ts", "**/*.js"]
}